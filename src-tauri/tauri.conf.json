{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Reviewly",
  "version": "0.1.4",
  "identifier": "dev.volnei.reviewly",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Reviewly",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 18 },
        "transparent": true,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "Developer ID Application",
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 175 },
        "applicationFolderPosition": { "x": 480, "y": 175 }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCNjI4MTlGOEY1OENEMTAKUldRUXpWaVBuNEZpS3lIc3U4ZytmYk1KUU12V3dsOHNnZFNCdWRVMC9GK1c1c3hCcS9hTS96S0gK",
      "endpoints": ["https://github.com/volnei/reviewly/releases/latest/download/latest.json"]
    }
  }
}
